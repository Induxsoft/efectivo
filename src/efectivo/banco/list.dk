        //         tbody
        //         {
        //             #!
        //             go foreach.lobj(index:i, value:banco) with(cBancos)
        //             {
        //                 row = (i+1)
        //                 #$
        //                 tr
        //                 {
        //                     td{$"#<row>"}
        //                     td{$"#<@@(banco,'$nombre')>"}
        //                     td{a(href="#<@@(banco,'$website')>" target="_blank"){$"#<@@(banco,'$website')>"}}
        //                     td
        //                     {
        //                         a(class="btn btn-primary btn-xs m-1" href="./#<@@(banco,'sys_pk')>/"){$"Editar"}
        //                         button(class="btn btn-danger btn-xs m-1" onclick="InduxsoftCrudlModel.Delete(#<@@(banco,'sys_pk')>)"){$"Eliminar"}
        //                     }
