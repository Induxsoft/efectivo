#include "dkli.dkh"
#!
module "lib.dk"
{
    listarTiposDocumentos::
    {
        new params
        {
            @"datatable*": ifnull(@("&./documentos"),list.create())
            @"id": "sel_documento"
            new member "attributes"
            {
                @"class": "induxsoft-form-select"
                @"name": "documento"
                @"required": ""
            }
            @"value_field": "id"
            @"text_field": "const"
            @"selected": @("$input/documento")
        }

        do uie.dbSelect(params)

        exception {/*ignore*/}
    }

