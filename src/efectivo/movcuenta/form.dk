#include "dkli.dkh"
#!
module "form.dk"
{
    #include "functions.dkh"
    #include "serialize.dkh"

    do @context.begin(@crud_context)
    
    #$
    div(class="container")
    {
        h1{$"Form"}

        p{"ERROR:"}
        p{$"#<@('$error/message')>"}
        hr{}

        p{"PARÁMETROS:"}
        p{$"#<to.json(@('&parameters'))>"}
        hr{}

        p{"DATA (.):"}
        p{$"#<to.json(@('&.'))>"}
    }
}