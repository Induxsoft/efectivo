    {
        //params<"auth_transferencia">:dbr.security.isauth(db,@CXP_SEC_PRIVID_REALIZAR_TRANSFERENCIA)
        //if not(@@(params,"#auth_transferencia")) { do rise_error(0,"No autorizado")}

