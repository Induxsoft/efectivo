        new ndata
        {
            @"auditado":if(parse.bool(@@(data,"active")),1,0)
            @"sys_recver":@@(data,"#sys_recver")
            @"sys_pk":@@(data,"#sys_pk")
        }
        ref result = dbr.save(db,"movcuenta",ndata)

        do dbr.apps.action.pos(result)
        do dbr.commit(db)
